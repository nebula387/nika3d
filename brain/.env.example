# Скопировать этот файл в .env и заполнить реальными значениями.
# .env НЕ должен попадать в git (см. .gitignore).

# ── LLM-провайдер ─────────────────────────────────────────────────────────────
# "lmstudio" — локально через LM Studio (рекомендуется)
# "groq"     — облако Groq (запасной)
LLM_PROVIDER=lmstudio

# LM Studio: сервер запускается кнопкой "Start Server" в LM Studio
# URL по умолчанию localhost:1234 — менять не нужно
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
# Имя модели — скопировать из LM Studio (отображается под названием модели)
LLM_MODEL=qwen2.5-7b-instruct

# Groq (если LLM_PROVIDER=groq):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=openai/gpt-oss-120b

# ── TTS-провайдер ─────────────────────────────────────────────────────────────
# "xtts"       — локально, EN+RU, клонирование голоса (рекомендуется)
# "piper"      — локально, быстро, только EN
# "elevenlabs" — облако, естественно, но платно
TTS_PROVIDER=xtts

# XTTS-v2 — голос для клонирования (путь к wav-файлу, 5-30 сек чистой речи)
# Оставить пустым → будет использоваться стандартный голос модели
XTTS_SPEAKER_WAV=
# "auto" = язык определяется автоматически по тексту, либо "en" или "ru"
XTTS_LANGUAGE=auto

# Piper TTS (если TTS_PROVIDER=piper)
PIPER_VOICE_PATH=

# ElevenLabs (если TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Мост Python <-> Godot ─────────────────────────────────────────────────────
BRIDGE_HOST=localhost
BRIDGE_PORT=8765

# ── Whisper ───────────────────────────────────────────────────────────────────
WHISPER_MODEL=base
