# Скопировать этот файл в .env и заполнить реальными значениями.
# .env НЕ должен попадать в git (см. .gitignore).

# --- LLM-провайдер ---
# Текущий выбор: Groq (https://console.groq.com)
# Быстрый бесплатный tier, хорошо для реального времени.
LLM_PROVIDER=groq

# Ключ API — получить на console.groq.com
LLM_API_KEY=

# Модель. Актуальная на 2026-07: openai/gpt-oss-120b
# (llama-3.3-70b отключён Groq 2026-06-17)
LLM_MODEL=openai/gpt-oss-120b

# --- TTS-провайдер ---
# "elevenlabs" — живой голос через API (рекомендуется)
# "piper"      — локально, без интернета
TTS_PROVIDER=elevenlabs

# ElevenLabs (если TTS_PROVIDER=elevenlabs)
# Ключ: зарегистрироваться на elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
# Голос: Rachel (тёплый, естественный) — ID по умолчанию
# Другие голоса: browsing на elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Модель: eleven_multilingual_v2 (качество) или eleven_flash_v2_5 (скорость)
ELEVENLABS_MODEL=eleven_multilingual_v2

# Piper TTS (если TTS_PROVIDER=piper)
PIPER_VOICE_PATH=

# --- Мост Python <-> Godot ---
BRIDGE_HOST=localhost
BRIDGE_PORT=8765

# --- Whisper ---
WHISPER_MODEL=base
